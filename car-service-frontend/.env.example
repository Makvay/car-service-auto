# ============================================
# КОНФИГУРАЦИЯ ДЛЯ ПРОДАКШН
# ============================================
# Скопируйте этот файл в .env и заполните значениями

# --------------------------------------------
# URL СЕРВИСОВ (ОБЯЗАТЕЛЬНО)
# --------------------------------------------
# Пример:
# REACT_APP_KEYCLOAK_URL=https://keycloak.auto-service.ru
# REACT_APP_API_URL=https://api.auto-service.ru
# REACT_APP_FRONTEND_URL=https://app.auto-service.ru

# --------------------------------------------
# KEYCLOAK (по умолчанию НЕ менять)
# --------------------------------------------
REACT_APP_KEYCLOAK_REALM=car-service
REACT_APP_KEYCLOAK_CLIENT=frontend-client

# ============================================
# ЛОКАЛЬНАЯ РАЗРАБОТКА (раскомментируйте)
# ============================================
# REACT_APP_KEYCLOAK_URL=http://localhost:8180
# REACT_APP_API_URL=http://localhost:8091
# REACT_APP_FRONTEND_URL=http://localhost:3000